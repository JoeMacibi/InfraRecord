{
  "dashboard": {
    "id": null,
    "title": "InfraRecord - Cluster Health",
    "tags": ["infrarecord", "kubernetes"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "CPU Utilization",
        "type": "timeseries",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{application="infrarecord-backend"}",
            "legendFormat": "Memory Used"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "HTTP Requests",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count[5m])",
            "legendFormat": "Req/s"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
